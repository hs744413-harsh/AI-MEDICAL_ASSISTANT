# ── API Keys ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ── LLM Config ────────────────────────────────────────────────
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=20

# ── ML Model ─────────────────────────────────────────────────
# Percentage (0–100). Predictions below this threshold get a low-confidence warning.
ML_CONFIDENCE_THRESHOLD=20.0

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Search / Scrape ───────────────────────────────────────────
TAVILY_MAX_RESULTS=3
SCRAPE_MAX_CHARS=3000
TAVILY_TIMEOUT_SECONDS=8
SCRAPE_TIMEOUT_SECONDS=10

# ── Reliability / Retry ───────────────────────────────────────
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=0.4
RETRY_MAX_DELAY_SECONDS=2.0
RETRY_JITTER_SECONDS=0.25

# ── Pipeline Step Timeouts ────────────────────────────────────
PIPELINE_STEP_TIMEOUT_SEARCH_SECONDS=12
PIPELINE_STEP_TIMEOUT_SCRAPE_SECONDS=14
PIPELINE_STEP_TIMEOUT_WRITER_SECONDS=25
PIPELINE_STEP_TIMEOUT_CRITICAL_SECONDS=25
